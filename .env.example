# Copy this file to `.env` for local development.

# ── Market data (existing) ───────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=yahoo-finance15.p.rapidapi.com
TERMINAL_SECRET=replace_this_for_local_use

# ── Stripe billing (optional — leaves Pricing modal in waitlist mode if blank) ──
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PRO_PLUS_MONTHLY=price_...
STRIPE_PRICE_PRO_PLUS_ANNUAL=price_...
STRIPE_TRIAL_DAYS=7
APP_BASE_URL=https://captainfredric.github.io/The-Terminal-Meridian/

# ── AI commentary panel (optional — falls back to template-driven insights) ──
# Either OPENAI_API_KEY or ANTHROPIC_API_KEY enables real LLM commentary.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_COMMENTARY_MODEL=gpt-4o-mini
