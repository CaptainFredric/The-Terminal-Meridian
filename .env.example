# Copy this file to `.env` for local development.

# ── Market data (existing) ───────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=yahoo-finance15.p.rapidapi.com
TERMINAL_SECRET=replace_this_for_local_use

# ── Deployment / CORS ────────────────────────────────────────────────
# Comma-separated allowlist of frontend origins permitted to call /api/*.
# Defaults already cover GH Pages + 127.0.0.1 — only override for custom domains.
# CORS_ORIGINS=https://captainfredric.github.io,https://meridian.example.com
#
# Set to "1" when frontend and backend live on different origins (e.g. GH Pages
# frontend → Render backend). Switches the session cookie to SameSite=None;Secure.
# Leave unset (or "0") for pure local dev served from 127.0.0.1.
# CROSS_SITE_COOKIES=0
#
# Override the SQLite path. Useful in production to point at a persistent disk.
# TERMINAL_DB_PATH=/opt/render/data/terminal.db

# ── Stripe billing (optional — leaves Pricing modal in waitlist mode if blank) ──
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PRO_PLUS_MONTHLY=price_...
STRIPE_PRICE_PRO_PLUS_ANNUAL=price_...
STRIPE_TRIAL_DAYS=7
APP_BASE_URL=https://captainfredric.github.io/The-Terminal-Meridian/

# ── AI commentary panel (optional — falls back to template-driven insights) ──
# Either OPENAI_API_KEY or ANTHROPIC_API_KEY enables real LLM commentary.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_COMMENTARY_MODEL=gpt-4o-mini
