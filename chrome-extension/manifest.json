{
  "manifest_version": 3,
  "name": "Meridian Quick Quotes",
  "version": "0.1.0",
  "description": "Pop-up watchlist, ticker badges, and quick links into the Meridian Market Terminal.",
  "action": {
    "default_title": "Meridian Quick Quotes",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:4173/*",
    "http://localhost:4173/*",
    "https://captainfredric.github.io/*"
  ]
}
